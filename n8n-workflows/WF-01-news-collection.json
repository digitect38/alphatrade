{
  "id": "2",
  "name": "WF-01 News Collection",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "minutes", "minutesInterval": 5 }]
        }
      },
      "id": "schedule-1",
      "name": "Every 5 Minutes",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 0]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://core-engine:8000/collect/news",
        "options": { "timeout": 30000 }
      },
      "id": "http-1",
      "name": "Collect News",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [220, 0]
    }
  ],
  "connections": {
    "Every 5 Minutes": {
      "main": [[{ "node": "Collect News", "type": "main", "index": 0 }]]
    }
  },
  "settings": { "executionOrder": "v1" }
}
