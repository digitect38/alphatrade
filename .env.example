# ===========================================
# AlphaTrade Environment Variables
# Copy to .env and fill in actual values
# ===========================================

# --- TimescaleDB ---
POSTGRES_USER=alphatrade
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=alphatrade

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME

# --- n8n ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME
N8N_ENCRYPTION_KEY=CHANGE_ME_random_32_chars

# --- Grafana ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME

# --- 한국투자증권 OpenAPI ---
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_CANO=
KIS_ACNT_PRDT_CD=01

# --- DART (공시) ---
DART_API_KEY=

# --- TradingView ---
TRADINGVIEW_WEBHOOK_SECRET=

# --- LLM API ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- KakaoTalk ---
KAKAO_ACCESS_TOKEN=

# --- Security ---
API_AUTH_KEY=            # Set to enable API key auth (empty = no auth)
RATE_LIMIT_MAX=300       # Max requests per window per IP
RATE_LIMIT_WINDOW=60     # Window in seconds

# --- Cloudflare Tunnel ---
CLOUDFLARE_TUNNEL_TOKEN=

# --- Core Engine ---
CORE_ENGINE_HOST=0.0.0.0
CORE_ENGINE_PORT=8000

# --- Portfolio ---
INITIAL_CAPITAL=10000000         # 초기 자본금 (원)

# --- Risk Management ---
RISK_MAX_TOTAL_CAPITAL=500000    # 총 투자 한도 (원)
RISK_MAX_PER_STOCK=250000        # 종목당 최대 (원)
RISK_MAX_POSITION_RATIO=0.20     # 종목당 최대 비중
RISK_STOP_LOSS_PCT=-0.03         # 손절 기준
RISK_TAKE_PROFIT_PCT=0.10        # 익절 기준
RISK_MAX_DAILY_LOSS_PCT=-0.02    # 일간 최대 손실
RISK_MAX_DAILY_TRADES=10         # 일간 최대 거래

# --- Strategy ---
STRATEGY_WEIGHT_MOMENTUM=0.30
STRATEGY_WEIGHT_MEAN_REVERSION=0.25
STRATEGY_WEIGHT_VOLUME=0.20
STRATEGY_WEIGHT_SENTIMENT=0.25
STRATEGY_BUY_THRESHOLD=0.15
STRATEGY_SELL_THRESHOLD=-0.15

# --- Position Sizing ---
SIZING_MAX_POSITION_PCT=0.15     # 포트폴리오 대비 종목 비중
SIZING_MAX_CASH_PER_ORDER_PCT=0.30
SIZING_MIN_ORDER_VALUE=100000    # 최소 주문금액

# --- Scanner ---
SCANNER_GAP_THRESHOLD=0.02       # 갭 감지 기준
SCANNER_TOP_N=5                  # 상위 종목 수
SCANNER_MAX_BUY_PER_SCAN=3       # 스캔당 최대 매수

# --- HTTP Timeout ---
HTTP_TIMEOUT_DEFAULT=15.0        # 기본 HTTP 타임아웃 (초)
HTTP_TIMEOUT_LLM=30.0            # LLM API 타임아웃 (초)

# --- Cache ---
CACHE_TECHNICAL_TTL=60           # 기술적 분석 캐시 (초)
